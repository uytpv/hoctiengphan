[debug] [2026-04-05T20:02:57.669Z] >>> [apiv2][query] PUT http://127.0.0.1:8080/emulator/v1/projects/hoc-tieng-phan:securityRules [none]
[debug] [2026-04-05T20:02:57.669Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/hoc-tieng-phan:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Kiểm tra Role Admin\n    function isAdmin() {\n      return request.auth != null && \n             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&\n             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n\n    // 1. DỮ LIỆU HỆ THỐNG (GLOBAL DATA)\n    match /roadmaps/{roadmapId} {\n      allow read: if request.auth != null;\n      allow write: if isAdmin();\n    }\n\n    match /vocabularies/{vocId} {\n      allow read: if request.auth != null;\n      // Cho phép tất cả user đăng nhập được TẠO từ vựng mới (Global Shared)\n      allow create: if request.auth != null;\n      // Chỉ admin mới có quyền sửa/xóa các từ vựng đã có\n      allow update, delete: if isAdmin();\n    }\n\n    match /grammar_lessons/{lessonId} {\n      allow read: if request.auth != null;\n      allow write: if isAdmin();\n    }\n\n    match /categories/{catId} {\n      allow read: if request.auth != null;\n      allow write: if isAdmin();\n    }\n\n    match /grammars/{grammarId} {\n      allow read: if request.auth != null;\n      allow write: if isAdmin();\n    }\n\n    match /exercises/{exerciseId} {\n      allow read: if request.auth != null;\n      allow write: if isAdmin();\n    }\n\n    // Activity Collection\n    match /activities/{activityId} {\n      allow read: if true;\n      allow write: if isAdmin();\n    }\n\n    // Study Plan Collections\n    match /study_plans/{planId} {\n      allow read: if true;\n      allow write: if isAdmin();\n    }\n\n    match /study_plan_weeks/{weekId} {\n      allow read: if true;\n      allow write: if isAdmin();\n    }\n\n    match /lessons/{lessonId} {\n      allow read: if request.auth != null;\n      allow write: if isAdmin();\n    }\n\n    // 2. DỮ LIỆU NGƯỜI DÙNG CÁ NHÂN (USER DATA)\n    // Chỉ bảo vệ dữ liệu cá nhân: UID phải trùng khớp\n    match /users/{userId} {\n      allow read, write: if request.auth != null && request.auth.uid == userId;\n      // Quản trị viên có toàn quyền đọc/ghi tất cả profile\n      allow read, write: if isAdmin();\n      \n      // Cho phép truy cập vào các sub-collections (progress, notebook_vocabularies, notebook_grammar)\n      match /{allSubcollections=**} {\n        allow read, write: if request.auth != null && request.auth.uid == userId;\n        allow read, write: if isAdmin();\n      }\n    }\n  }\n}\n"}]}}
